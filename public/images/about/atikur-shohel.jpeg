				}</style><link rel="icon" href="https://ecomgarden.com/wp-content/uploads/2024/02/Social-icon-150x150.jpg" sizes="32x32" /><link rel="icon" href="https://ecomgarden.com/wp-content/uploads/2024/02/Social-icon-300x300.jpg" sizes="192x192" /><link rel="apple-touch-icon" href="https://ecomgarden.com/wp-content/uploads/2024/02/Social-icon-300x300.jpg" /><meta name="msapplication-TileImage" content="https://ecomgarden.com/wp-content/uploads/2024/02/Social-icon-300x300.jpg" /><style id="wp-custom-css">/* Loop Animation */
@keyframes loopAnimation {
    0% { transform: scale(1); }
    50% { transform: scale(1.06); }
    100% { transform: scale(1); }
}

/* Hover Animation */
@keyframes hoverAnimation {
    0% { transform: scale(1); }
    50% { transform: scale(1); }
    100% { transform: scale(1); }
}

/* Apply Loop Animation */
.anibtn {
    animation: loopAnimation 2s infinite;
}

/* Apply Hover Animation on Hover */
.anibtn:hover {
    animation: hoverAnimation 0.5s forwards;
}


nav.elementor-nav-menu--dropdown.elementor-nav-menu__container {
	
		max-width: 300px;
	left: -70px;
